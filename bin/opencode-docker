#!/bin/bash
set -e

# OpenCode Docker wrapper script
# Add this directory to your PATH to run OpenCode from anywhere

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Default workspace to current directory if not specified
WORKSPACE="${OPENCODE_WORKSPACE:-$(pwd)}"

# Generate random port in ephemeral range (49152-65534) for brainstorming server
BRAINSTORM_PORT=$((49152 + RANDOM % 16383))

docker run --rm -it \
    --read-only \
    --tmpfs /tmp:exec,size=512m \
    --cap-drop ALL \
    --security-opt seccomp=unconfined \
    --memory=2g \
    --cpus=2 \
    -p "${BRAINSTORM_PORT}:${BRAINSTORM_PORT}" \
    -e BRAINSTORM_PORT="${BRAINSTORM_PORT}" \
    -e BRAINSTORM_HOST=0.0.0.0 \
    -v "$HOME/.opencode-docker:/app:rw" \
    -v "$HOME/.gitconfig:/app/.gitconfig:ro" \
    -v "$PROJECT_DIR/config:/app/.config/opencode:ro" \
    -v "$WORKSPACE:/workspace:rw" \
    -v "$HOME/.opencode-docker/secrets:/run/secrets:ro" \
    opencode-cli /workspace "$@"