#!/usr/bin/env bash
#
# OpenCode Docker wrapper script
# Add this directory to your PATH to run OpenCode from anywhere
#
# Options:
#   -b, --brainstorm    Enable brainstorming server (exposes port for real-time collaboration)

set -e

# Default workspace to current directory if not specified
WORKSPACE="${OPENCODE_WORKSPACE:-$(pwd)}"

BRAINSTORM_PORT=""
BRAINSTORM_HOST=""
PORT_MAPPING=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -b|--brainstorm)
            BRAINSTORM_PORT=$((49152 + RANDOM % 16383))
            BRAINSTORM_HOST="0.0.0.0"
            PORT_MAPPING="-p ${BRAINSTORM_PORT}:${BRAINSTORM_PORT}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [ -t 0 ]; then
    DOCKER_FLAGS="-it"
else
    DOCKER_FLAGS="-i"
fi

docker run --rm $DOCKER_FLAGS \
	--read-only \
	--tmpfs /tmp:exec,size=512m \
    --cap-drop=ALL \
    --security-opt=no-new-privileges \
    --memory=2g \
    --cpus=2 \
    ${PORT_MAPPING} \
    ${BRAINSTORM_PORT:+-e BRAINSTORM_PORT="${BRAINSTORM_PORT}"} \
    ${BRAINSTORM_HOST:+-e BRAINSTORM_HOST="${BRAINSTORM_HOST}"} \
    -v "$HOME/.opencode-docker:/app:rw" \
    -v "$HOME/.gitconfig:/app/.gitconfig:ro" \
    -v "$HOME/.config/opencode:/app/.config/opencode:ro" \
    -v "$HOME/.opencode-docker/secrets:/run/secrets:ro" \
    -v "$WORKSPACE:/workspace:rw" \
    opencode-docker:latest /workspace "$@"